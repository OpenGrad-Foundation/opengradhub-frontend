    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@clerk/testing": "^1.4.4",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
